# ─── Supabase ─────────────────────────────────────────────────────────────────
# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private — server-side only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for text-embedding-3-small (AI-1 semantic search) and GPT-4o-mini (AI-2 content)
OPENAI_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Server-side secret — never expose to the client
STRIPE_SECRET_KEY=
# Signing secret for verifying webhook payloads
STRIPE_WEBHOOK_SECRET=
# Public — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production; http://localhost:3000 locally
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── PayPal (P1 — secondary payment, add when implementing) ───────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── Resend (P1 — email campaigns, add when implementing) ─────────────────────
RESEND_API_KEY=
